{
    "dots": {
        "url": "https://github.com/PandoraDots/caelestia.git",
        "branch": "main"
    },
    "wallpaper": {
        "postHook": "bash \"PANDORA_ROOT_PLACEHOLDER/scripts/wallpaper-posthook.sh\""
    },
    "theme": {
        "enableTerm": true,
        "enableHypr": true,
        "enableDiscord": true,
        "enableSpicetify": true,
        "enableFuzzel": true,
        "enableBtop": true,
        "enableGtk": true,
        "enableQt": true,
        "enableChromium": true,
        "enableZed": false,
        "enableCava": true,
        "postHook": "sudo /usr/share/sddm/themes/caelestia/scripts/sync.sh --posthook",
        "iconTheme": "Papirus-Dark",
        "iconThemeLight": "Papirus-Light",
        "iconThemeDark": "Papirus-Dark"
    },
    "toggles": {
        "communication": {
            "equibop": {
                "enable": true,
                "match": [{ "class": "equibop" }, { "class": "equicord" }],
                "command": ["equibop"],
                "move": true
            },
            "whatsapp": {
                "enable": false
            }
        },
        "music": {
            "spotify": {
                "enable": true,
                "match": [
                    { "class": "Spotify" },
                    { "initialTitle": "Spotify" },
                    { "initialTitle": "Spotify Free" }
                ],
                "command": ["spicetify", "watch", "-s"],
                "move": true
            }
        },
        "todo": {
            "todoist": {
                "enable": false
            },
            "planify": {
                "enable": true,
                "match": [
                    { "class": "io.github.alainm23.planify" },
                    { "class": "planify" }
                ],
                "command": ["io.github.alainm23.planify"],
                "move": true
            }
        }
    }
}
