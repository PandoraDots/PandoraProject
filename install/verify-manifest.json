{
    "packages": {
        "required": [
            "base-devel",
            "git",
            "cmake",
            "ninja",
            "python",
            "python-hatchling",
            "python-hatch-vcs",
            "python-pillow",
            "hyprland",
            "foot",
            "fastfetch",
            "btop",
            "fish",
            "paru",
            "pipewire",
            "pipewire-pulse",
            "wireplumber",
            "sddm",
            "uwsm",
            "quickshell-git",
            "qt6-shadertools",
            "libpipewire",
            "libqalculate",
            "aubio",
            "cava",
            "cmatrix",
            "tty-clock",
            "ttf-material-symbols-variable",
            "ttf-cascadia-code-nerd",
            "nvidia-utils",
            "mesa",
            "intel-media-driver",
            "power-profiles-daemon",
            "qtengine",
            "libcava",
            "darkly-bin",
            "gvfs",
            "fuse2",
            "tumbler",
            "thunar-volman"
        ],
        "optional": [
            "pipewire-jack",
            "caelestia-sddm-locklike-git",
            "spotify",
            "spicetify-cli",
            "cursor-bin",
            "equibop-bin",
            "zapzap",
            "planify",
            "freedownloadmanager",
            "vlc",
            "gvfs-mtp"
        ],
        "cachyos_drivers": true
    },
    "commands": {
        "required": [
            "caelestia",
            "qs",
            "paru",
            "hyprctl",
            "foot",
            "fastfetch",
            "btop",
            "fish",
            "uwsm"
        ],
        "optional": [
            "cava",
            "cmatrix",
            "tty-clock",
            "cursor",
            "spotify",
            "spicetify"
        ]
    },
    "files": {
        "required": [
            "~/.config/caelestia/cli.json",
            "~/.config/caelestia/shell.json",
            "~/.config/caelestia/hypr-user.lua",
            "~/.config/caelestia/hypr-vars.lua",
            "~/.config/fastfetch/config.jsonc",
            "~/.config/cava/config",
            "~/.config/fish/functions/fish_greeting.fish",
            "~/.config/caelestia/gpu-profile.env",
            "~/.local/bin/waywallen",
            "~/.local/share/applications/org.waywallen.waywallen.desktop"
        ],
        "optional": [
            "~/.face",
            "~/Pictures/Wallpapers",
            "$PANDORA_ROOT/Wallpapers/glassesredjapan.jpg",
            "~/.config/xfce4/xfconf/xfce-perchannel-xml/thunar.xml",
            "~/.config/user-dirs.dirs",
            "~/.local/share/icons/hicolor/scalable/apps/org.waywallen.waywallen.svg"
        ]
    },
    "file_contains": [
        {
            "path": "~/.config/caelestia/hypr-user.lua",
            "pattern": "kb_layout",
            "label": "teclado br-abnt2 no Hyprland"
        },
        {
            "path": "~/.config/caelestia/hypr-user.lua",
            "pattern": "pandora-info",
            "label": "dashboard workspace 1"
        },
        {
            "path": "~/.config/caelestia/hypr-vars.lua",
            "pattern": "SUPER + G",
            "label": "Super+G Spotify/Spicetify"
        },
        {
            "path": "~/.config/caelestia/shell.json",
            "pattern": "\"recolour\": true",
            "label": "recolour icons ativo"
        },
        {
            "path": "~/.config/user-dirs.dirs",
            "pattern": "XDG_PICTURES_DIR=\"$HOME/Pictures\"",
            "label": "user-dirs Pictures (English)"
        },
        {
            "path": "~/.config/xfce4/xfconf/xfce-perchannel-xml/thunar.xml",
            "pattern": "THUNAR_EXECUTE_SHELL_SCRIPT_ASK",
            "label": "Thunar shell scripts ASK"
        },
        {
            "path": "~/.config/fastfetch/config.jsonc",
            "pattern": "berserk-logo",
            "label": "logo Berserk no fastfetch"
        },
        {
            "path": "~/.config/fastfetch/config.jsonc",
            "pattern": "______",
            "label": "banner ASCII Caelestia no fastfetch"
        },
        {
            "path": "~/.config/fish/functions/fish_greeting.fish",
            "pattern": "PANDORA_DASHBOARD",
            "label": "fish_greeting sem banner duplicado"
        }
    ],
    "systemd_system": {
        "required": [
            "sddm.service",
            "power-profiles-daemon.service"
        ],
        "optional": [
            "nvidia-powerd.service",
            "nekro_sense.service"
        ]
    },
    "systemd_user": {
        "required": [
            "pandora-gpu-profile.timer"
        ],
        "optional": []
    },
    "sddm": {
        "theme": "caelestia",
        "keyboard": "br-abnt2"
    },
    "scheme": {
        "name": "inferno"
    },
    "runtime_checks": {
        "hypr_monitor_position": true,
        "hypr_config_errors": true,
        "caelestia_shell": true,
        "dashboard_windows": true,
        "spicetify_theme": true,
        "waywallen_wallpaper": true
    }
}
